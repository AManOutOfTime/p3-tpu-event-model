{
  "name": "fa2_forward",
  "description": "Unpipelined static schedule for FlashAttention-2 forward pass. The event-based simulator should consume this, resolve dependencies, and assign operations to HW units over time. Pipelining (overlap across inner-loop iterations) is expected to emerge from the simulator's scheduling, not be baked in here.",
  "symbolic_params": {
    "N": "sequence length",
    "d_head": "per-head dim (d_model / num_heads)",
    "Br": "row block size (rows of Q per outer iter)",
    "Bc": "col block size (rows of K,V per inner iter)",
    "Tr": "ceil(N / Br)  -- outer loop trip count",
    "Tc": "ceil(N / Bc)  -- inner loop trip count"
  },
  "hw_units": [
    "SystolicArray",
    "Tandem1",
    "Tandem2",
    "Tandem3",
    "AccessCore1",
    "AccessCore2",
    "DMA"
  ],
  "tensors": {
    "Q":   {"shape": ["N", "d_head"], "location": "HBM"},
    "K":   {"shape": ["N", "d_head"], "location": "HBM"},
    "V":   {"shape": ["N", "d_head"], "location": "HBM"},
    "O":   {"shape": ["N", "d_head"], "location": "HBM"},
    "L":   {"shape": ["N"],           "location": "HBM"},
    "Q_tile":   {"shape": ["Br", "d_head"], "location": "SRAM"},
    "K_tile":   {"shape": ["Bc", "d_head"], "location": "SRAM"},
    "V_tile":   {"shape": ["Bc", "d_head"], "location": "SRAM"},
    "K_tile_T": {"shape": ["d_head", "Bc"], "location": "SRAM"},
    "S_tile":   {"shape": ["Br", "Bc"],     "location": "SRAM"},
    "P_tile":   {"shape": ["Br", "Bc"],     "location": "SRAM"},
    "O_acc":    {"shape": ["Br", "d_head"], "location": "SRAM"},
    "Temp":     {"shape": ["Br", "d_head"], "location": "SRAM"},
    "m":        {"shape": ["Br"], "location": "SRAM", "init": "-inf"},
    "m_new":    {"shape": ["Br"], "location": "SRAM"},
    "l":        {"shape": ["Br"], "location": "SRAM", "init": "0"},
    "correction": {"shape": ["Br"], "location": "SRAM"}
  },
  "loops": {
    "outer": {"var": "i", "range": [0, "Tr"], "owns": ["Q_tile", "O_acc", "m", "l"]},
    "inner": {"var": "j", "range": [0, "Tc"], "nested_in": "outer"}
  },
  "operations": [
    {
      "id": "load_Q",
      "loop": "outer",
      "op": "dma_load",
      "hw_unit": "DMA",
      "granularity": "PerTile",
      "inputs":  [{"name": "Q",      "rows": "i*Br : (i+1)*Br"}],
      "outputs": [{"name": "Q_tile"}],
      "depends_on": []
    },
    {
      "id": "init_O_acc",
      "loop": "outer",
      "op": "fill",
      "hw_unit": "AccessCore1",
      "granularity": "PerTile",
      "inputs":  [],
      "outputs": [{"name": "O_acc", "value": 0}],
      "depends_on": []
    },
    {
      "id": "init_m",
      "loop": "outer",
      "op": "fill",
      "hw_unit": "AccessCore1",
      "granularity": "PerElement",
      "inputs":  [],
      "outputs": [{"name": "m", "value": "-inf"}],
      "depends_on": []
    },
    {
      "id": "init_l",
      "loop": "outer",
      "op": "fill",
      "hw_unit": "AccessCore1",
      "granularity": "PerElement",
      "inputs":  [],
      "outputs": [{"name": "l", "value": 0}],
      "depends_on": []
    },

    {
      "id": "load_K",
      "loop": "inner",
      "op": "dma_load",
      "hw_unit": "DMA",
      "granularity": "PerTile",
      "inputs":  [{"name": "K", "rows": "j*Bc : (j+1)*Bc"}],
      "outputs": [{"name": "K_tile"}],
      "depends_on": []
    },
    {
      "id": "load_V",
      "loop": "inner",
      "op": "dma_load",
      "hw_unit": "DMA",
      "granularity": "PerTile",
      "inputs":  [{"name": "V", "rows": "j*Bc : (j+1)*Bc"}],
      "outputs": [{"name": "V_tile"}],
      "depends_on": []
    },
    {
      "id": "transpose_K",
      "loop": "inner",
      "op": "transpose",
      "hw_unit": "AccessCore2",
      "granularity": "PerTile",
      "inputs":  [{"name": "K_tile"}],
      "outputs": [{"name": "K_tile_T"}],
      "depends_on": ["load_K"]
    },
    {
      "id": "matmul_QK",
      "loop": "inner",
      "op": "matmul",
      "hw_unit": "SystolicArray",
      "granularity": "PerTile",
      "inputs":  [{"name": "Q_tile"}, {"name": "K_tile_T"}],
      "outputs": [{"name": "S_tile"}],
      "expression": "S_tile = Q_tile @ K_tile_T",
      "depends_on": ["load_Q", "transpose_K"]
    },
    {
      "id": "scale_S",
      "loop": "inner",
      "op": "elementwise_scale",
      "hw_unit": "Tandem1",
      "granularity": "PerElement",
      "inputs":  [{"name": "S_tile"}],
      "outputs": [{"name": "S_tile"}],
      "expression": "S_tile = S_tile / sqrt(d_head)",
      "depends_on": ["matmul_QK"]
    },
    {
      "id": "rowmax_S",
      "loop": "inner",
      "op": "reduce_rowmax",
      "hw_unit": "AccessCore1",
      "granularity": "PerRowSubTile",
      "inputs":  [{"name": "S_tile"}],
      "outputs": [{"name": "rowmax_tmp", "shape": ["Br"]}],
      "expression": "rowmax_tmp[i] = max over j of S_tile[i, j]",
      "depends_on": ["scale_S"]
    },
    {
      "id": "update_m_correction",
      "loop": "inner",
      "op": "elementwise",
      "hw_unit": "AccessCore1",
      "granularity": "PerRowSubTile",
      "inputs":  [{"name": "m"}, {"name": "rowmax_tmp"}],
      "outputs": [{"name": "m_new"}, {"name": "correction"}],
      "expression": "m_new[i] = max(m[i], rowmax_tmp[i]); correction[i] = exp(m[i] - m_new[i])",
      "depends_on": ["rowmax_S"]
    },
    {
      "id": "compute_P",
      "loop": "inner",
      "op": "elementwise_exp",
      "hw_unit": "Tandem3",
      "granularity": "PerElement",
      "inputs":  [{"name": "S_tile"}, {"name": "m_new"}],
      "outputs": [{"name": "P_tile"}],
      "expression": "P_tile[i,j] = exp(S_tile[i,j] - m_new[i])",
      "depends_on": ["update_m_correction"]
    },
    {
      "id": "update_l",
      "loop": "inner",
      "op": "reduce_rowsum_fma",
      "hw_unit": "AccessCore1",
      "granularity": "PerElement",
      "inputs":  [{"name": "l"}, {"name": "correction"}, {"name": "P_tile"}],
      "outputs": [{"name": "l"}],
      "expression": "l[i] = correction[i] * l[i] + sum over j of P_tile[i, j]",
      "depends_on": ["compute_P", "update_m_correction"]
    },
    {
      "id": "rescale_O",
      "loop": "inner",
      "op": "elementwise_scale",
      "hw_unit": "Tandem2",
      "granularity": "PerElement",
      "inputs":  [{"name": "O_acc"}, {"name": "correction"}],
      "outputs": [{"name": "O_acc"}],
      "expression": "O_acc[i, :] = O_acc[i, :] * correction[i]",
      "depends_on": ["update_m_correction"]
    },
    {
      "id": "matmul_PV",
      "loop": "inner",
      "op": "matmul",
      "hw_unit": "SystolicArray",
      "granularity": "PerTile",
      "inputs":  [{"name": "P_tile"}, {"name": "V_tile"}],
      "outputs": [{"name": "Temp"}],
      "expression": "Temp = P_tile @ V_tile",
      "depends_on": ["compute_P", "load_V"]
    },
    {
      "id": "accumulate_O",
      "loop": "inner",
      "op": "elementwise_add",
      "hw_unit": "Tandem2",
      "granularity": "PerTile",
      "inputs":  [{"name": "O_acc"}, {"name": "Temp"}],
      "outputs": [{"name": "O_acc"}],
      "expression": "O_acc = O_acc + Temp",
      "depends_on": ["rescale_O", "matmul_PV"]
    },
    {
      "id": "advance_m",
      "loop": "inner",
      "op": "copy",
      "hw_unit": "AccessCore1",
      "granularity": "PerElement",
      "inputs":  [{"name": "m_new"}],
      "outputs": [{"name": "m"}],
      "expression": "m = m_new",
      "depends_on": ["compute_P", "update_l", "rescale_O"]
    },

    {
      "id": "finalize_O",
      "loop": "outer",
      "phase": "post_inner_loop",
      "op": "elementwise_div",
      "hw_unit": "Tandem2",
      "granularity": "PerElement",
      "inputs":  [{"name": "O_acc"}, {"name": "l"}],
      "outputs": [{"name": "O_acc"}],
      "expression": "O_acc[i, :] = O_acc[i, :] / l[i]",
      "depends_on": ["accumulate_O"]
    },
    {
      "id": "finalize_L",
      "loop": "outer",
      "phase": "post_inner_loop",
      "op": "elementwise",
      "hw_unit": "AccessCore1",
      "granularity": "PerElement",
      "inputs":  [{"name": "m"}, {"name": "l"}],
      "outputs": [{"name": "L_tile", "shape": ["Br"]}],
      "expression": "L_tile[i] = m[i] + log(l[i])",
      "depends_on": ["advance_m", "finalize_O"]
    },
    {
      "id": "store_O",
      "loop": "outer",
      "phase": "post_inner_loop",
      "op": "dma_store",
      "hw_unit": "DMA",
      "granularity": "PerTile",
      "inputs":  [{"name": "O_acc"}],
      "outputs": [{"name": "O", "rows": "i*Br : (i+1)*Br"}],
      "depends_on": ["finalize_O"]
    },
    {
      "id": "store_L",
      "loop": "outer",
      "phase": "post_inner_loop",
      "op": "dma_store",
      "hw_unit": "DMA",
      "granularity": "PerTile",
      "inputs":  [{"name": "L_tile"}],
      "outputs": [{"name": "L", "rows": "i*Br : (i+1)*Br"}],
      "depends_on": ["finalize_L"]
    }
  ],
  "notes": [
    "Operations marked loop='inner' execute Tc times per outer iteration.",
    "Operations marked loop='outer' execute Tr times.",
    "depends_on lists intra-iteration dependencies. The simulator must additionally enforce that an inner-iteration op at step j depends on the same op at step j-1 if it reads/writes a loop-carried tensor (m, l, O_acc).",
    "Loop-carried tensors: m, l, O_acc -- updated each inner iteration j and read by iteration j+1.",
    "HW unit assignments mirror the example schedule image. Adjust to match dummy_schedule.cpp if it uses different unit names.",
    "matmul_QK and matmul_PV both target SystolicArray -- they cannot run concurrently in the same iteration but CAN pipeline across iterations (j's PV with j+1's QK)."
  ]
}
